upstream proxorchestrator_app {
    server unix:/run/proxorchestrator/gunicorn.sock fail_timeout=0;
}

upstream proxorchestrator_ws {
    server unix:/run/proxorchestrator/daphne.sock fail_timeout=0;
}

server {
    listen {{ WEB_PORT }} ssl;
    server_name _;

    ssl_certificate     /opt/proxorchestrator/certs/proxorchestrator.crt;
    ssl_certificate_key /opt/proxorchestrator/certs/proxorchestrator.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    # Allow very large disk image uploads (up to 50 GB)
    client_max_body_size 50G;

    # Increase timeouts for large uploads
    proxy_read_timeout   3600s;
    proxy_send_timeout   3600s;
    proxy_connect_timeout 75s;

    location /static/ {
        alias /opt/proxorchestrator/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location /media/ {
        alias {{ UPLOAD_ROOT }}/;
        internal;
    }

    location /ws/ {
        proxy_pass          http://proxorchestrator_ws;
        proxy_http_version  1.1;
        proxy_set_header    Upgrade           $http_upgrade;
        proxy_set_header    Connection        "upgrade";
        proxy_set_header    Host              $http_host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_read_timeout  86400s;
        proxy_send_timeout  86400s;
    }

    location / {
        proxy_pass          http://proxorchestrator_app;
        proxy_set_header    Host              $http_host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_redirect      off;

        # Support large chunked uploads
        proxy_request_buffering off;
    }

    # VM console WebSocket proxy — target written by ProxOrchestrator after wizard completes
    include /opt/proxorchestrator/deploy/proxmox_ws.conf;
}

# ACME HTTP-01 challenge server (managed by ProxOrchestrator — empty when not in use)
include /opt/proxorchestrator/deploy/acme-challenge.conf;
